<section class="hero">
  <h2>Cloud, DevOps & AI Solutions</h2>
  <p>Helping businesses build scalable, secure, and modern cloud platforms.</p>
  <a class="btn" href="#contact">Get Started</a>
</section>

<section class="section" id="services">
  <h2>Our Services</h2>

  <div class="features">
    <div class="card">
      <h3>Cloud Architecture</h3>
      <p>Design scalable infrastructure on AWS, Azure and GCP for modern applications.</p>
    </div>

    <div class="card">
      <h3>DevOps Automation</h3>
      <p>CI/CD pipelines, containerization, Kubernetes and infrastructure automation.</p>
    </div>

    <div class="card">
      <h3>Security & DevSecOps</h3>
      <p>Application security scanning, compliance automation and runtime protection.</p>
    </div>

    <div class="card">
      <h3>AI Platforms</h3>
      <p>Build intelligent applications using modern AI frameworks and cloud services.</p>
    </div>
  </div>
</section>

<section class="section" id="contact">
  <h2>Contact Us</h2>

  <form class="contact-form" action="contact.php" method="POST">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="text" name="phone" placeholder="Contact Number" required>
    <input type="email" name="email" placeholder="Email Address" required>
    <textarea name="query" placeholder="Your Query" required></textarea>
    <button type="submit" class="btn">Send Message</button>
  </form>
</section>

<section class="cta">
  <h2>Ready to transform your business?</h2>
  <p>Let us help you modernize your infrastructure and accelerate innovation.</p>
  <a class="btn" href="#contact">Contact Us</a>
</section>

<footer>
  <p>© 2026 samirs.co.in | All Rights Reserved</p>
</footer>

